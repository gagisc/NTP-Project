# GCP overlay parameters
# Copy this file to params.env (gitignored) and fill in your values.
# CI/CD generates this automatically from Terraform outputs and GitHub Secrets.

# Full Artifact Registry image URI
# e.g. us-central1-docker.pkg.dev/my-project/ntp-server/ntp-server:latest
AR_IMAGE=us-central1-docker.pkg.dev/YOUR_PROJECT_ID/ntp-server/ntp-server:latest

# Static IP resource name from Terraform output: ntp_static_ip_name
STATIC_IP_NAME=ntp-server-cluster-ntp-ip

# GCP Workload Identity service account email
# e.g. ntp-server-cluster-workload@YOUR_PROJECT_ID.iam.gserviceaccount.com
GCP_WORKLOAD_SA=ntp-server-cluster-workload@YOUR_PROJECT_ID.iam.gserviceaccount.com
