# AWS overlay parameters
# Copy this file to params.env (gitignored) and fill in your values.
# CI/CD generates this automatically from Terraform outputs and GitHub Secrets.

# Full ECR image URI  e.g. 123456789012.dkr.ecr.us-east-1.amazonaws.com/ntp-server:latest
ECR_IMAGE=123456789012.dkr.ecr.us-east-1.amazonaws.com/ntp-server:latest

# Elastic IP allocation ID from Terraform output: ntp_eip_allocation_id
EIP_ALLOCATION_ID=eipalloc-xxxxxxxxxxxxxxxxx
